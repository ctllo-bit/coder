#!/bin/bash
LOG_FILE="${TRIM_PKGVAR}/info.log"
INSTALL_TARGETDIR="/opt/code-server"
CODER_WORKSPACEDIR="/vol1/1000/coderProject"

#获取处理器架构
ARCH=""
case "${TRIM_SYS_ARCH}" in
    x86_64|x86)
        ARCH="amd64"
        ;;
    aarch64|arm)
        ARCH="arm64"
        ;;
    armv7l|armv7)
        ARCH="armv7l"
        ;;
    *)
        log_msg "不支持的架构: $TRIM_SYS_ARCH"
        exit 1
        ;;
esac


### This script is called after the user installs the application.
log_msg() {
    echo "$(date '+%Y-%m-%d %H:%M:%S') - $1" >> ${LOG_FILE}
}

download_latest() {
    local LATEST_VERSION
    log_msg "正在获取最新版本信息..."
    LATEST_VERSION=$(curl -s https://api.github.com/repos/coder/code-server/releases/latest | grep -Po '"tag_name": "v\K[^"]*')
    if [ -z "$LATEST_VERSION" ]; then
        log_msg "获取版本失败，请检查网络。"
        return 1
    fi
    local DICT_FILE="code-server-${LATEST_VERSION}-linux-${ARCH}.tar.gz"
    log_msg "最新版本为: $LATEST_VERSION，准备下载: ${DICT_FILE}"

    cd $CODER_WORKSPACEDIR || {
        log_msg "无法进入 ${CODER_WORKSPACEDIR}"
        return 1
    }

    local DICT_URL="https://github.com/coder/code-server/releases/download/v${LATEST_VERSION}/${DICT_FILE}"
    wget -c "$DICT_URL" --show-progress || {
        log_msg "下载失败"
        return 1
    }

    log_msg "最新版本下载完成: ${CODER_WORKSPACEDIR}/$DICT_FILE"

    return 0
}


log_msg "开始安装 code-server"

files=("$CODER_WORKSPACEDIR"/code-server-*-linux-${ARCH}.tar.gz)

if [ -e "${files[0]}" ]; then
    log_msg "发现压缩包: ${files[0]}"
else
    log_msg "目录中没有 code-server 压缩包"
    download_latest || {
        log_msg "下载最新版本失败"
        exit 1
    }
fi




